# Stripe Payment Link. Create at https://dashboard.stripe.com/payment-links
# Set to the full https://buy.stripe.com/... URL
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Direct download URL for the notarized DMG (GitHub Releases or Cloudflare R2)
# e.g. https://github.com/YOUR_USERNAME/Tappit/releases/download/v1.0.0/Tappit-1.0.0.dmg
NEXT_PUBLIC_DOWNLOAD_URL=

# Waitlist submission endpoint (POST JSON {"email": "..."}).
# e.g. https://api.gettappit.com/api/v1/waitlist
NEXT_PUBLIC_WAITLIST_ENDPOINT=

# The runtime CTA mode (waitlist vs purchase) is configured via the Cloudflare
# Worker (worker/index.ts) that reads CTA_MODE, WAITLIST_URL, and PURCHASE_URL
# from wrangler.toml [vars]. Deploy with `wrangler deploy`.
