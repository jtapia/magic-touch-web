# Stripe Payment Link. Create at https://dashboard.stripe.com/payment-links
# Set to the full https://buy.stripe.com/... URL
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Direct download URL for the notarized DMG (GitHub Releases or Cloudflare R2)
# e.g. https://github.com/YOUR_USERNAME/MagicTouch/releases/download/v1.0.0/MagicTouch-1.0.0.dmg
NEXT_PUBLIC_DOWNLOAD_URL=

# Product Hunt product page (post-launch).
# e.g. https://www.producthunt.com/products/magictouch
NEXT_PUBLIC_PH_PRODUCT_URL=

# Product Hunt Upcoming page (pre-launch). Used when PH_PRODUCT_URL is empty.
# e.g. https://www.producthunt.com/upcoming/magictouch
NEXT_PUBLIC_PH_UPCOMING_URL=

# Waitlist submission endpoint. Any service accepting POST JSON {"email": "..."}.
# Examples:
#   Formspree:      https://formspree.io/f/YOUR_FORM_ID
#   Buttondown:     https://api.buttondown.email/v1/subscribers (needs auth header, edit Waitlist.tsx)
#   Own worker:     https://waitlist.yourdomain.com/subscribe
# Leave blank to hide the waitlist form.
NEXT_PUBLIC_WAITLIST_ENDPOINT=
